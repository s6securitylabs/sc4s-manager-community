# SC4S Manager configuration. Copy to /opt/sc4s/manager.env.
# Generate real values from an approved secret store, for example:
#   openssl rand -hex 32
SC4S_MANAGER_PROXY_SECRET=change-me-with-random-value
SC4S_MANAGER_API_TOKEN=change-me-with-random-value

# Optional one-time/manual browser login token for protected internal tests.
SC4S_MANAGER_MANUAL_LOGIN_TOKEN=

# Optional: Library source base URL.
# Defaults to https://sechub.s6ops.com (SecHub curated packs).
# Set to a private hub URL to use an alternative source, or set to "none" to start with no pre-configured source.
SC4S_LIBRARY_SOURCE_URL=
