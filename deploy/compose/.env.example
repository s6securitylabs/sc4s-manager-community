# Compose/image settings. Copy to /opt/sc4s/.env.
# Pin both images for production; do not rely on latest for release evidence.
SC4S_IMAGE=ghcr.io/splunk/splunk-connect-for-syslog/container3:3.43.0
SC4S_MANAGER_VERSION=1.0.2

# Host-published ports.
SC4S_SOURCE_LISTEN_TCP_PORT=514
SC4S_SOURCE_LISTEN_UDP_PORT=514
SC4S_SOURCE_LISTEN_RFC6587_PORT=601
SC4S_SOURCE_LISTEN_TLS_PORT=6514
SC4S_LISTEN_STATUS_PORT=8080
SC4S_MANAGER_PORT=8090
