  "supported_transports": [
    {
      "id": "tls_rfc5425",
      "label": "TLS syslog RFC5425",
      "transport": "tls",
      "recommended": true,
      "default_port": 6514,
      "syslog_protocol": "rfc5425",
      "framing": "octet_counted",
      "envelope": "ietf_rfc5424",
      "payload_format": "csv",
      "notes": "Best production option: encrypted transport with explicit framing and timezone-qualified header support."
    },
    {
      "id": "tcp_rfc5424",
      "label": "TCP syslog RFC5424/IETF",
      "transport": "tcp",
      "recommended": false,
      "default_port": 601,
      "syslog_protocol": "rfc5424_over_tcp",
      "framing": "line_delimited",
      "envelope": "ietf_rfc5424",
      "payload_format": "csv",
      "notes": "Acceptable when TLS is terminated upstream or unavailable."
    },
    {
      "id": "udp_bsd",
      "label": "UDP BSD syslog",
      "transport": "udp",
      "recommended": false,
      "default_port": 514,
      "syslog_protocol": "udp_syslog",
      "framing": "datagram",
      "envelope": "bsd_rfc3164_or_headerless",
      "payload_format": "csv",
      "notes": "Legacy/lab only; risk of event loss and timezone ambiguity."
    },
    {
      "id": "tcp_bsd",
      "label": "TCP BSD syslog",
      "transport": "tcp",
      "recommended": false,
      "default_port": 514,
      "syslog_protocol": "tcp_syslog",
      "framing": "line_delimited",
      "envelope": "bsd_rfc3164_or_headerless",
      "payload_format": "csv",
      "notes": "Legacy/plain TCP fallback."
    }
  ],
  "recommended_transport": "tls_rfc5425",
  "source_log_version": {
    "name": "PAN-OS syslog field descriptions",
    "min": "10.2",
    "max": "11.1+",
    "notes": "Official PAN-OS syslog schemas are positional CSV and vary by release; parser routes by Type and tolerates trailing fields. Confirm exact PAN-OS/Panorama version during field validation."
  },
  "validation": {
    "date_validated": "2026-05-28",
    "validated_by": "S6 Security Labs",
    "source_log_version": "Official PAN-OS 11.1 docs and Splunk Add-on current docs reviewed 2026-05-28; synthetic-equivalent fixtures for 15 PAN-OS families.",
    "sc4s_version": "3.43.0",
    "splunk_version": "TA-compatible, Splunk version not lab-readback validated",
    "evidence": "Schema and fixture validation only. Live downstream read-back from a real PAN-OS/Panorama source is still required before validated/field_validated promotion."
  },
  "test_event_sets": [
    {
      "id": "panos_csv_single_line",
      "label": "PAN-OS default CSV single-line fixtures",
      "path": "test-events/pan_panos_test_events.txt",
      "format": "csv",
      "wire_format": "headerless_syslog_payload",
      "envelope": "none",
      "serialization": "csv",
      "event_count": 15,
      "events_per_file": "multiple",
      "event_boundary": "line",
      "record_separator": "\\n",
      "one_event_per_line": true,
      "multiline": false,
      "unique_events": true,
      "marker_tokens": [
        "SC4S-PAN-TRAFFIC-MARKER",
        "SC4S-PAN-THREAT-MARKER",
        "SC4S-PAN-WILDFIRE-MARKER",
        "SC4S-PAN-SYSTEM-MARKER",
        "SC4S-PAN-CONFIG-MARKER",
        "SC4S-PAN-HIPMATCH-MARKER",
        "SC4S-PAN-USERID-MARKER",
        "SC4S-PAN-GLOBALPROTECT-MARKER",
        "SC4S-PAN-AUTH-MARKER",
        "SC4S-PAN-DECRYPTION-MARKER",
        "SC4S-PAN-TUNNEL-MARKER",
        "SC4S-PAN-CORRELATION-MARKER",
        "SC4S-PAN-IPTAG-MARKER",
        "SC4S-PAN-GTP-MARKER",
        "SC4S-PAN-SCTP-MARKER"
      ],
      "timestamp_policy": {
        "source_time_mode": "field_without_timezone_source_local",
        "primary_field": "Generated Time",
        "primary_timezone": null,
        "fallback_fields": [
          "Receive Time",
          "syslog_header"
        ],
        "fallback_time_mode": "source_local_time_requires_timezone",
        "fallback_timezone": null,
        "requires_source_timezone_when_fields_missing": [
          "Generated Time",
          "Receive Time"
        ],
        "notes": "PAN-OS CSV timestamps normally omit timezone. Prefer timezone-qualified RFC5424/RFC5425 header if present; otherwise configure/record source timezone."
      },
      "field_delimiting": {
        "style": "positional_csv",
        "field_separator": ",",
        "quote_character": "\"",
        "escape_policy": "PAN-OS default syslog CSV; preserve empty FUTURE_USE fields and trailing fields",
        "allows_empty_fields": true,
        "notes": "Field positions are family-specific. Do not collapse delimiters or convert to JSON when targeting the Splunk TA."
      },
      "expected_families": [
        "traffic",
        "threat",
        "wildfire",
        "system",
        "config",
        "hipmatch",
        "userid",
        "globalprotect",
        "auth",
        "decryption",
        "tunnel",
        "correlation",
        "iptag",
        "gtp",
        "sctp"
      ]
    }
  ],
