{
  "schema_version": "0.1",
  "id": "pan_panos",
  "version": "0.1.0",
  "url": "https://pan.dev/panos/docs/syslog/",
  "description": "First-class SecHub Resources SC4S pack for Palo Alto Networks PAN-OS, Panorama, and compatible PAN-OS syslog streams. Routes official PAN-OS CSV log families to Splunk TA-compatible pan:* sourcetypes while preserving the original payload.",
  "display_name": "Palo Alto Networks PAN-OS",
  "vendor": "palo_alto_networks",
  "product": "pan-os",
  "default_index": "netfw",
  "default_source": "pan_panos",
  "listener": {
    "source_id": "PAN_PANOS",
    "transport": "tls",
    "port": 6514,
    "env": {
      "SC4S_LISTEN_PAN_PANOS_TLS_PORT": "6514",
      "SOURCE_ALL_SET_APPEND": "PAN_PANOS"
    }
  },
  "sourcetypes": {
    "traffic": "pan:traffic",
    "threat": "pan:threat",
    "wildfire": "pan:wildfire",
    "system": "pan:system",
    "config": "pan:config",
    "hipmatch": "pan:hipmatch",
    "userid": "pan:userid",
    "globalprotect": "pan:globalprotect",
    "auth": "pan:auth",
    "decryption": "pan:decryption",
    "tunnel": "pan:tunnel",
    "correlation": "pan:correlation",
    "iptag": "pan:iptag",
    "gtp": "pan:gtp",
    "sctp": "pan:sctp"
  },
  "event_families": [
    {
      "id": "traffic",
      "label": "Traffic",
      "match_engine": "pcre",
      "match": "(^|[[:space:]])[0-9]+,[0-9]{4}/[0-9]{2}/[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2},[^,]+,TRAFFIC,",
      "expected_sourcetype": "pan:traffic",
      "primary_id_field": "Session ID",
      "required_fields": [
        "Type",
        "Receive Time",
        "Serial Number"
      ],
      "timestamp_fields": [
        "Receive Time",
        "Generated Time",
        "Start Time"
      ]
    },
    {
      "id": "threat",
      "label": "Threat / URL / vulnerability / spyware",
      "match_engine": "pcre",
      "match": "(^|[[:space:]])[0-9]+,[0-9]{4}/[0-9]{2}/[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2},[^,]+,THREAT,",
