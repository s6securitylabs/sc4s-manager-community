# Palo Alto Networks PAN-OS / Panorama syslog into SC4S Manager
# Recommended: TLS/RFC5425 or TCP/RFC5424/IETF syslog from the PAN-OS Syslog Server Profile.
SC4S_LISTEN_PAN_PANOS_TLS_PORT=6514
SOURCE_ALL_SET_APPEND=PAN_PANOS
# Legacy/plain options when source cannot use TLS:
# SC4S_LISTEN_PAN_PANOS_TCP_PORT=601
# SC4S_LISTEN_PAN_PANOS_UDP_PORT=514
