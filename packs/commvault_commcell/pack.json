{
  "id": "commvault_commcell",
  "version": "0.1.0",
  "url": "https://documentation.commvault.com/11.40/software/configuring_syslog_server.html",
  "description": "Commvault CommCell syslog/SIEM pack for AuditTrail, Events, and Alerts. Includes SC4S dedicated TLS listener guidance, parser config, family-specific Splunk sourcetypes, CIM-oriented normalized fields, Splunk props/transforms/eventtypes/tags exports, and test events for validation.",
  "display_name": "Commvault CommCell",
  "vendor": "commvault",
  "product": "commcell",
  "default_index": "commvault",
  "default_source": "commvault_commcell",
  "listener": {
    "source_id": "COMMVAULT_COMMCELL",
    "transport": "tls",
    "port": 20029,
    "env": {
      "SC4S_LISTEN_COMMVAULT_COMMCELL_TLS_PORT": "20029",
      "SOURCE_ALL_SET_APPEND": "COMMVAULT_COMMCELL"
    }
  },
  "sourcetypes": {
    "audit": "commvault:commcell:audittrail",
    "event": "commvault:commcell:events",
    "alert": "commvault:commcell:alerts"
  },
  "event_families": [
    {
      "id": "audit",
      "label": "AuditTrail",
      "match": "^(AuditTrail:|Opid[[:space:]]*=)",
      "primary_id_field": "Opid",
      "timestamp_fields": [
        "Utctimestamp",
        "Audittime"
      ],
      "match_engine": "pcre",
      "expected_sourcetype": "commvault:commcell:audittrail",
      "required_fields": [
        "Opid"
      ]
    },
    {
      "id": "event",
      "label": "Events",
      "match": "^(Events?:|Eventid[[:space:]]*=)",
      "primary_id_field": "Eventid",
      "timestamp_fields": [
        "Utctimestamp",
        "Occurrencetime"
      ],
      "match_engine": "pcre",
      "expected_sourcetype": "commvault:commcell:events",
      "required_fields": [
        "Eventid"
      ]
    },
    {
      "id": "alert",
      "label": "Alerts",
      "match": "^(Alerts?:|Alertid[[:space:]]*=)",
      "primary_id_field": "Alertid",
      "timestamp_fields": [
        "Utctimestamp",
        "Alerttime"
      ],
      "match_engine": "pcre",
      "expected_sourcetype": "commvault:commcell:alerts",
      "required_fields": [
        "Alertid"
      ]
    }
  ],
  "normalized_fields": {
    "vendor": "Commvault",
    "product": "CommCell",
    "vendor_product": "commvault:commcell",
    "action": "cv_event_type",
    "signature_id": "Opid|Eventid|Alertid",
    "signature": "Operation|Description|Alertname",
    "severity": "Severitylevel|Eventseverity|Alertseverity",
    "user": "Username",
    "dest": "Computer|Clientname",
    "process": "Program",
    "process_id": "Jobid",
    "app": "AgentType|backup",
    "message": "Details|Description|Alertdescription"
  },
  "artifacts": {
    "sc4s": [
      "sc4s/app_parsers/syslog/app-commvault_commcell.conf",
      "sc4s/postfilters/app-postfilter-commvault_commcell-drop-alerts.conf",
      "sc4s/env.example"
    ],
    "splunk": [
      "splunk/default/props.conf",
      "splunk/default/transforms.conf",
      "splunk/default/eventtypes.conf",
      "splunk/default/tags.conf"
    ],
    "test_events": [
      "test-events/commvault_test_events.txt"
    ],
    "scripts": [
      "scripts/send_tls_20029.sh"
    ],
    "docs": [
      "README.md"
    ]
  },
  "supported_transports": [
    {
      "id": "tls_rfc5425",
      "label": "TLS syslog RFC5425",
      "transport": "tls",
      "recommended": true,
      "default_port": 20029,
      "notes": "Recommended production transport for Commvault CommCell into SC4S.",
      "syslog_protocol": "rfc5425",
      "framing": "octet_counted",
      "envelope": "ietf_rfc5424",
      "payload_format": "custom_application"
    },
    {
      "id": "tcp_rfc5424",
      "label": "TCP syslog RFC5424",
      "transport": "tcp",
      "recommended": false,
      "default_port": 20029,
      "notes": "Use when TLS termination is handled elsewhere or source cannot use TLS.",
      "syslog_protocol": "rfc5424_over_tcp",
      "framing": "line_delimited",
      "envelope": "ietf_rfc5424",
      "payload_format": "custom_application"
    },
    {
      "id": "udp_bsd",
      "label": "UDP syslog BSD/headerless",
      "transport": "udp",
      "recommended": false,
      "default_port": 514,
      "notes": "Supported for lab/legacy use only; avoid for production where event loss matters.",
      "syslog_protocol": "udp_syslog",
      "framing": "datagram",
      "envelope": "bsd_rfc3164_or_headerless",
      "payload_format": "custom_application"
    },
    {
      "id": "tcp_bsd",
      "label": "TCP syslog BSD/headerless",
      "transport": "tcp",
      "recommended": false,
      "default_port": 514,
      "notes": "Legacy/plain TCP option when source emits BSD/headerless payloads.",
      "syslog_protocol": "tcp_syslog",
      "framing": "line_delimited",
      "envelope": "bsd_rfc3164_or_headerless",
      "payload_format": "custom_application"
    }
  ],
  "recommended_transport": "tls_rfc5425",
  "source_log_version": {
    "name": "Commvault Platform Release",
    "min": null,
    "max": null,
    "notes": "Commvault syslog/SIEM field shape validated from current documentation and representative samples; set min/max when customer source version is confirmed."
  },
  "validation": {
    "date_validated": "2026-05-26",
    "validated_by": "S6 Security Labs",
    "source_log_version": "Commvault documentation current as of 2026-05-26; lab samples for AuditTrail, Events, Alerts",
    "sc4s_version": "3.43.0",
    "splunk_version": "10.2.3",
    "evidence": "SC4S TLS 20029 -> Splunk HEC -> index=commvault with family-specific sourcetypes validated."
  },
  "test_event_sets": [
    {
      "id": "commvault_headerless_single_line",
      "label": "Commvault headerless single-line AuditTrail/Events/Alerts fixtures",
      "path": "test-events/commvault_test_events.txt",
      "format": "custom_application",
      "wire_format": "headerless_syslog_payload",
      "envelope": "none",
      "serialization": "text",
      "event_count": 3,
      "events_per_file": "multiple",
      "event_boundary": "line",
      "record_separator": "\\n",
      "one_event_per_line": true,
      "multiline": false,
      "unique_events": true,
      "marker_tokens": [
        "<MARKER>_AUDIT",
        "<MARKER>_EVENT",
        "<MARKER>_ALERT"
      ],
      "timestamp_policy": {
        "source_time_mode": "field_utc_epoch",
        "primary_field": "Utctimestamp",
        "primary_timezone": "UTC",
        "fallback_fields": [
          "Audittime",
          "Occurrencetime",
          "Alerttime"
        ],
        "fallback_time_mode": "source_local_time_requires_timezone",
        "fallback_timezone": null,
        "requires_source_timezone_when_fields_missing": [
          "Utctimestamp"
        ],
        "notes": "Commvault samples include Utctimestamp epoch seconds and local display-time fields. Parser should prefer Utctimestamp. If a source omits it, the pack must be amended with the source host or application timezone before production validation."
      },
      "field_delimiting": {
        "style": "braced_key_value",
        "field_pattern": "<Key> = {<Value>}",
        "field_separator": "space_between_pairs",
        "value_wrapper": "curly_braces",
        "allows_spaces_in_values": true,
        "notes": "Do not split values on raw spaces inside braces. Treat each physical line as the event boundary for these fixtures."
      },
      "expected_families": [
        "audit",
        "event",
        "alert"
      ]
    }
  ],
  "schema_version": "0.1",
  "export_artifacts": [
